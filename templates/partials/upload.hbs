<div class="container">
    <form action="/consult" method="post" name="form1">
    <div class="form-group">
        <label for="d">Your Name :</label>
        <input type="textarea" id="d" name="fullname" placeholder="Full Name" >
    </div>
    <br>
    <div class="form-group">
        <label for="c">Your email :</label>
        <input type="email" id="c" name="email" placeholder="E-mail" >
    </div>
    <br>
    <div class="form-group">
        <label for="b">Please Elaborate your problem :</label>
        <input type="textarea" id="b" name="problem" placeholder="Problem" >
    </div>
    <br>
    <div class="form-group">
        <label for="pickerid">Choose the type of media you want us to send:</label>
        <input list="mediazzz" id="pickerid" name="mediatype" placeholder="Media-type" >
        <datalist id="mediazzz">
        <option value="Image"> Image </option>
        <option value="Audio"> Audio</option>
        <option value="Video"> Video</option>
        </datalist>
    </div><br>
        <div class="form-group">
        <label for="b">Please choose a file :</label>
        <input type="file" id="h" name="ah" >
         </div>
    <br><br>
    <center>
        <input type="reset">
        <input type="submit">
    </center>
    
</form>
</div>
