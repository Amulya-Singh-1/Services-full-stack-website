<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
    <title> New User </title>
    <link rel="stylesheet" href="style.css">
  </head>
  <body>
    {{>navbar}}
    <br>
    <h2 class="center"> Login as an existing user </h2>
    <br>
    <center>
    <form action="" class="my-form">  
    <div >
        <label for="validationDefaultUsername">Username</label>
        <input type="text" id="validationDefaultUsername" placeholder="Username" size="30 !important" required>
        <br>
        <br>
        <label for="pswd"> Password </label>
        <input type="password" placeholder="password" size="30 !important" required>
    </div> 
    <br>
    <br>
    <button class="btn btn-success" type="submit"> Submit </button>
</form>  
    <br>
    <label for=""> Not an existing user ? </label>
    <button class="btn-warning"> <a href="register"> Create Account </a></button>
</center>
    
    <br>
    {{>footer}}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>
</html>
